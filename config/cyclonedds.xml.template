<?xml version="1.0" encoding="UTF-8"?>
<!--
  ferox-audio-sim DDS — env-driven Cyclone DDS configuration.

  TWO OPTIONAL ENV VARS (read by docker/entrypoint-dds.sh):

    FEROX_DDS_INTERFACE   Network interface to pin (e.g. "tailscale0").
                          Empty/unset => Cyclone auto-detects.

    FEROX_DDS_PEERS       Space-separated peer IPs for cross-network
                          discovery (Tailscale/VPN). Empty/unset =>
                          multicast-only on local LAN.

  COMMON SETUPS:
    Host + nav on same LAN:           neither var set    (multicast works)
    Host + Vast.ai over Tailscale:    both set           (dev cross-machine)
    Host + remote LLM box over VPN:   both set           (prod cross-machine)

  ALWAYS:
    MaxAutoParticipantIndex=120 — keeps room when nav/speech/audio share
    a host UDP port pool.
-->
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <Interfaces>
        ${CYCLONE_INTERFACE_BLOCK}
      </Interfaces>
      <AllowMulticast>spdp</AllowMulticast>
    </General>
    <Discovery>
      <Peers>
        ${CYCLONE_PEERS_BLOCK}
      </Peers>
      <MaxAutoParticipantIndex>120</MaxAutoParticipantIndex>
    </Discovery>
  </Domain>
</CycloneDDS>
